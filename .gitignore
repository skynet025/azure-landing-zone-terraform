# -------------------------------------------------------------------
# Terraform local working directories and state files
# -------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
plan.out
crash.log
crash.*.log

# -------------------------------------------------------------------
# Local environment-specific tfvars must never be versioned
# -------------------------------------------------------------------
config/*.tfvars
!config/*.tfvars.example
terraform.tfvars
# -------------------------------------------------------------------
# Terraform override files
# -------------------------------------------------------------------
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# -------------------------------------------------------------------
# Terraform CLI local config
# -------------------------------------------------------------------
.terraformrc
terraform.rc

# -------------------------------------------------------------------
# Local admin / helper artifacts
# -------------------------------------------------------------------
graph.dot
federated-credential.json
federated-credential-*.json

# -------------------------------------------------------------------
# Editors / OS
# -------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db